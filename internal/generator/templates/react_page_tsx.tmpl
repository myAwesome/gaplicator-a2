import { useState, useEffect } from 'react';
import type { {{.StructName}}, Create{{.StructName}}Input } from '../types/{{.Singular}}';
import { list{{.PluralName}}, create{{.StructName}}, update{{.StructName}}, delete{{.StructName}} } from '../api/{{.Singular}}';
{{range .FKImports}}import type { {{.RefStruct}} } from '../types/{{.RefSingular}}';
import { list{{.RefPlural}} } from '../api/{{.RefSingular}}';
{{end}}{{range .M2MRelations}}import type { {{.RefStruct}} } from '../types/{{.RefSingular}}';
import { list{{.RefPlural}} } from '../api/{{.RefSingular}}';
{{end}}
const EMPTY_FORM: Create{{.StructName}}Input = {
{{range .FormFields}}  {{.Name}}: {{.Default}},
{{end}}{{range .M2MRelations}}  {{.IDsField}}: [],
{{end}}};

export default function {{.ComponentName}}() {
  const [items, setItems] = useState<{{.StructName}}[]>([]);
  const [editing, setEditing] = useState<{{.StructName}} | null>(null);
  const [form, setForm] = useState<Create{{.StructName}}Input>(EMPTY_FORM);
  const [showForm, setShowForm] = useState(false);
  const [page, setPage] = useState(1);
  const [total, setTotal] = useState(0);
  const limit = 20;
  const [sortBy, setSortBy] = useState('id');
  const [sortDir, setSortDir] = useState<'asc' | 'desc'>('desc');
{{if .HasFilters}}  const [q, setQ] = useState('');
  const [filters, setFilters] = useState<Record<string, string>>({});
{{end}}{{range .FKImports}}  const [{{.OptionsVar}}, {{.SetterVar}}] = useState<{{.RefStruct}}[]>([]);
{{end}}{{range .M2MRelations}}  const [{{.OptionsVar}}, {{.SetterVar}}] = useState<{{.RefStruct}}[]>([]);
{{end}}
{{if .HasRefs}}  useEffect(() => { load(1); loadRefs(); }, []);
{{else}}  useEffect(() => { load(1); }, []);
{{end}}
{{if .HasRefs}}  async function loadRefs() {
    try {
{{range .FKImports}}      {{.SetterVar}}((await list{{.RefPlural}}(1, 1000)).data);
{{end}}{{range .M2MRelations}}      {{.SetterVar}}((await list{{.RefPlural}}(1, 1000)).data);
{{end}}    } catch (e) { console.error(e); }
  }

{{end}}  async function load(p: number, sb = sortBy, sd = sortDir{{if .HasFilters}}, f = filters, search = q{{end}}) {
    try {
{{if .HasFilters}}      const params: Record<string, string> = { ...f };
      if (search) params['q'] = search;
      const res = await list{{.PluralName}}(p, limit, sb, sd, params);
{{else}}      const res = await list{{.PluralName}}(p, limit, sb, sd);
{{end}}      setItems(res.data);
      setTotal(res.total);
      setPage(p);
    } catch (e) { console.error(e); }
  }

  function handleSort(col: string) {
    const newDir = col === sortBy ? (sortDir === 'asc' ? 'desc' : 'asc') : 'desc';
    setSortBy(col);
    setSortDir(newDir);
    load(1, col, newDir);
  }
{{if .HasFilters}}
  function handleFilterChange(key: string, value: string) {
    const newFilters = value
      ? { ...filters, [key]: value }
      : Object.fromEntries(Object.entries(filters).filter(([k]) => k !== key));
    setFilters(newFilters);
    load(1, sortBy, sortDir, newFilters, q);
  }
{{if .HasSearch}}
  function handleSearch(newQ: string) {
    setQ(newQ);
    load(1, sortBy, sortDir, filters, newQ);
  }
{{end}}{{end}}
  function openCreate() {
    setEditing(null); setForm(EMPTY_FORM); setShowForm(true);
  }

  function openEdit(item: {{.StructName}}) {
    setEditing(item);
    setForm({
{{range .OpenEditFields}}      {{.Name}}: {{.Expr}},
{{end}}{{range .M2MRelations}}      {{.IDsField}}: (item.{{.AssocField}} ?? []).map((r: {{.RefStruct}}) => r.id),
{{end}}    });
    setShowForm(true);
  }

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    try {
{{if .NeedsPayload}}      const payload = {
        ...form,
{{range .PayloadFields}}        {{.Name}}: {{.Expr}},
{{end}}      };
      if (editing) await update{{.StructName}}(editing.id, payload);
      else await create{{.StructName}}(payload);
{{else}}      if (editing) await update{{.StructName}}(editing.id, form);
      else await create{{.StructName}}(form);
{{end}}      setShowForm(false); load(page);
    } catch (e) { console.error(e); }
  }

  async function handleDelete(id: number) {
    if (!confirm('Delete?')) return;
    try { await delete{{.StructName}}(id); load(page); } catch (e) { console.error(e); }
  }

  return (
    <div>
      <div className="page-header">
        <h1>{{.ModelName}}</h1>
        <button className="btn btn-primary" onClick={openCreate}>+ New</button>
      </div>
{{if .HasFilters}}
      <div className="filter-bar">
{{if .HasSearch}}        <input className="form-input" type="search" placeholder="Search..." value={q} onChange={e => handleSearch(e.target.value)} />
{{end}}{{range .FilterFields}}{{if .IsEnum}}        <select className="form-select" value={filters['{{.FieldName}}'] ?? ''} onChange={e => handleFilterChange('{{.FieldName}}', e.target.value)}>
          <option value="">All {{.Label}}</option>
          {{range .EnumValues}}<option value="{{.}}">{{.}}</option>
          {{end}}</select>
{{else if .IsFK}}        <select className="form-select" value={filters['{{.FieldName}}'] ?? ''} onChange={e => handleFilterChange('{{.FieldName}}', e.target.value)}>
          <option value="">All {{.Label}}</option>
          { {{.OptionsVar}}.map(opt => (<option key={opt.id} value={String(opt.id)}>{opt.{{.LabelField}}}</option>))}
        </select>
{{else if .IsBool}}        <select className="form-select" value={filters['{{.FieldName}}'] ?? ''} onChange={e => handleFilterChange('{{.FieldName}}', e.target.value)}>
          <option value="">All {{.Label}}</option>
          <option value="true">Yes</option>
          <option value="false">No</option>
        </select>
{{end}}{{end}}      </div>
{{end}}
      {showForm && (
        <div className="form-card">
          <form onSubmit={handleSubmit}>
{{range .FormInputs}}{{if .IsFK}}            <div className="form-group">
              <label className="form-label">{{.Label}}</label>
              <select className="form-select" value={form.{{.FieldName}} as number} onChange={e => setForm({...form, {{.FieldName}}: Number(e.target.value)})}{{if .Required}} required{{end}}>
                <option value={0}>-- select --</option>
                { {{.OptionsVar}}.map(opt => (<option key={opt.id} value={opt.id}>{opt.{{.LabelField}}}</option>))}
              </select>
            </div>
{{else if .IsEnum}}            <div className="form-group">
              <label className="form-label">{{.Label}}</label>
              <select className="form-select" value={form.{{.FieldName}} as string} onChange={e => setForm({...form, {{.FieldName}}: e.target.value})}{{if .Required}} required{{end}}>
                <option value="">-- select --</option>
                {{range .EnumValues}}<option value="{{.}}">{{.}}</option>
                {{end}}</select>
            </div>
{{else if .IsCheckbox}}            <div className="form-group form-group--checkbox">
              <label className="form-label"><input type="checkbox" checked={form.{{.FieldName}} as boolean} onChange={e => setForm({...form, {{.FieldName}}: e.target.checked})} /> {{.Label}}</label>
            </div>
{{else if .IsNumber}}            <div className="form-group">
              <label className="form-label">{{.Label}}</label>
              <input className="form-input" type="number" value={form.{{.FieldName}} as number} onChange={e => setForm({...form, {{.FieldName}}: Number(e.target.value)})}{{if .Required}} required{{end}} />
            </div>
{{else}}            <div className="form-group">
              <label className="form-label">{{.Label}}</label>
              <input className="form-input" type="{{.InputType}}" value={form.{{.FieldName}} as string} onChange={e => setForm({...form, {{.FieldName}}: e.target.value})}{{if .Required}} required{{end}} />
            </div>
{{end}}{{end}}{{range .M2MRelations}}            <div className="form-group">
              <label className="form-label">{{.Label}}</label>
              <select multiple className="form-select form-select--multi"
                value={((form.{{.IDsField}} ?? []) as number[]).map(String)}
                onChange={e => setForm({...form, {{.IDsField}}: Array.from(e.target.selectedOptions).map(o => Number(o.value))})}>
                { {{.OptionsVar}}.map(opt => (<option key={opt.id} value={opt.id}>{opt.{{.LabelField}}}</option>))}
              </select>
            </div>
{{end}}            <div className="form-actions">
              <button type="submit" className="btn btn-primary">{editing ? 'Save' : 'Create'}</button>
              <button type="button" className="btn" onClick={() => setShowForm(false)}>Cancel</button>
            </div>
          </form>
        </div>
      )}

      <table className="data-table">
        <thead><tr>
          <th className={`sortable${sortBy === 'id' ? ' sorted' : ''}`} onClick={() => handleSort('id')}>id {sortBy === 'id' && (sortDir === 'asc' ? '▲' : '▼')}</th>
          {{range .TableColumns}}<th className={`sortable${sortBy === '{{.Key}}' ? ' sorted' : ''}`} onClick={() => handleSort('{{.Key}}')}>{{.Label}} {sortBy === '{{.Key}}' && (sortDir === 'asc' ? '▲' : '▼')}</th>
          {{end}}{{range .M2MRelations}}<th>{{.Label}}</th>
          {{end}}<th></th>
        </tr></thead>
        <tbody>
          {items.map(item => (
            <tr key={item.id}>
              <td>{item.id}</td>
{{range .TableCells}}              <td>{{.Expr}}</td>
{{end}}{{range .M2MRelations}}              <td>{(item.{{.AssocField}} ?? []).map((r: {{.RefStruct}}) => <span key={r.id} className="chip">{r.{{.LabelField}}}</span>)}</td>
{{end}}              <td>
                <div className="row-actions">
                  <button className="btn btn-sm" onClick={() => openEdit(item)}>Edit</button>
                  <button className="btn btn-sm btn-danger" onClick={() => handleDelete(item.id)}>Del</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <div className="pagination">
        <button className="btn" onClick={() => load(page - 1)} disabled={page <= 1}>Prev</button>
        <span>{page} / {Math.ceil(total / limit) || 1} ({total} total)</span>
        <button className="btn" onClick={() => load(page + 1)} disabled={page * limit >= total}>Next</button>
      </div>
    </div>
  );
}
