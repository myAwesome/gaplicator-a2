func list{{.Singular}}(db *gorm.DB) gin.HandlerFunc {
	return func(c *gin.Context) {
		page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
		limit, _ := strconv.Atoi(c.DefaultQuery("limit", "20"))
		if page < 1 {
			page = 1
		}
		if limit < 1 || limit > 100 {
			limit = 20
		}
		offset := (page - 1) * limit
		sortBy := c.DefaultQuery("sort_by", "id")
		sortDir := c.DefaultQuery("sort_dir", "desc")
		allowed{{.Singular}} := map[string]bool{ {{range .SortColumns}}"{{.}}": true, {{end}} }
		if !allowed{{.Singular}}[sortBy] {
			sortBy = "id"
		}
		if sortDir != "asc" && sortDir != "desc" {
			sortDir = "desc"
		}
{{if .HasM2M}}		query := db{{range .M2MRelations}}.Preload("{{.AssocField}}"){{end}}.Model(&{{.Type}}{})
{{else}}		query := db.Model(&{{.Type}}{})
{{end}}{{if .SearchColumns}}		if q := c.Query("q"); q != "" {
			like := "%" + strings.ReplaceAll(q, "%", "\\%") + "%"
			query = query.Where("{{range $i, $col := .SearchColumns}}{{if $i}} OR {{end}}{{$col}} ILIKE ?{{end}}", {{range $i, $col := .SearchColumns}}{{if $i}}, {{end}}like{{end}})
		}
{{end}}{{range .FilterColumns}}		if v := c.Query("{{.DBName}}"); v != "" {
{{if .IsNumeric}}			if n, err := strconv.Atoi(v); err == nil {
				query = query.Where("{{.DBName}} = ?", n)
			}
{{else if .IsBool}}			switch v {
			case "true", "1":
				query = query.Where("{{.DBName}} = ?", true)
			case "false", "0":
				query = query.Where("{{.DBName}} = ?", false)
			}
{{else}}			query = query.Where("{{.DBName}} = ?", v)
{{end}}		}
{{end}}		var total int64
		query.Count(&total)
		var rows []{{.Type}}
		if err := query.Order(sortBy + " " + sortDir).Offset(offset).Limit(limit).Find(&rows).Error; err != nil {
			c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
			return
		}
		c.JSON(http.StatusOK, gin.H{"data": rows, "total": total, "page": page, "limit": limit})
	}
}

